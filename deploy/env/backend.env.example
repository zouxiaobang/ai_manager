# 应用节点 192.168.0.114 后端环境变量示例
# 复制到：/opt/ai-manager/backend/backend.env
# MySQL / Redis 部署在数据节点 192.168.0.118（有线，与 116 同机双网卡）

SPRING_PROFILES_ACTIVE=prod

MYSQL_HOST=192.168.0.118
MYSQL_PORT=3306
MYSQL_DATABASE=ai_manager_admin
MYSQL_USER=ai_manager
MYSQL_PASSWORD=123456

REDIS_HOST=192.168.0.118
REDIS_PORT=6379
REDIS_DATABASE=0

# 笔记本正文存储：LOCAL 或 BAIDU_PAN
NOTE_STORAGE_TYPE=LOCAL

# 可选：覆盖百度网盘密钥（勿提交真实密钥到 Git）
# BAIDU_APP_KEY=
# BAIDU_SECRET_KEY=
